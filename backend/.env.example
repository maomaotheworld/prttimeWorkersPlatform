# 後端環境變數範例
# 複製此檔案為 .env 並填入實際值

# 伺服器端口
PORT=3005

# JWT 密鑰 (生產環境請使用強密碼)
JWT_SECRET=your-secret-key-here-please-change-in-production

# 環境 (development 或 production)
NODE_ENV=development

# PostgreSQL 連線字串（必填，部署環境不可使用本機 JSON 當正式資料來源）
DATABASE_URL=postgresql://username:password@host:5432/workers_db

# Google Sheets 服務帳戶設定（第一階段先做連線驗證）
GOOGLE_SHEETS_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n
GOOGLE_PROJECT_ID=your-google-cloud-project-id
GOOGLE_SHEET_ID=your-google-sheet-id

# 刪除資料前寄送 Excel 備份用的 SMTP 設定
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com

# 備份收件人（預設 tina83pan@yahoo.com.tw）
BACKUP_EMAIL_TO=tina83pan@yahoo.com.tw
